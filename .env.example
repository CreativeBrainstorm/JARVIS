# ============================================
# JARVIS AI Agent — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ---- LLM Provider ----
# Supported: openai, anthropic, gemini, ollama
JARVIS_LLM_PROVIDER=openai
JARVIS_LLM_MODEL=gpt-4o-mini

# API Keys (only needed for cloud providers)
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GOOGLE_API_KEY=your-google-api-key-here

# Ollama (for local models)
OLLAMA_BASE_URL=http://localhost:11434

# ---- Server ----
JARVIS_HOST=0.0.0.0
JARVIS_PORT=8000
JARVIS_DEBUG=true

# ---- Memory ----
JARVIS_CHROMA_PATH=./data/chroma
JARVIS_SQLITE_PATH=./data/sqlite/jarvis.db
JARVIS_MEMORY_WINDOW=20

# ---- Voice (optional) ----
PICOVOICE_ACCESS_KEY=your-picovoice-key-here
JARVIS_WAKE_WORD=jarvis
JARVIS_TTS_VOICE=en-US-GuyNeural

# ---- Logging ----
JARVIS_LOG_LEVEL=INFO
JARVIS_LOG_PATH=./data/logs
